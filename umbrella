#!/usr/bin/env bash
#
# umbrella - drive the CMake "super-build" (devel/CMakeLists.txt) or a single
# package under devel/ for a given Spack environment.
#
# Usage:
#   umbrella [-e|--env <env>] concretize|install [spack options]
#   umbrella [-e|--env <env>] config|build [options] [<package> ...]
#   umbrella [-e|--env <env>] test [<testname> ...]
#   umbrella deps [cmake-examine options]
#
# The Spack environment is chosen, in order of decreasing precedence, by:
#   1. the -e/--env <env> option,
#   2. the XEROSERE_UMBRELLA_ENV environment variable,
#   3. the hard-wired default "gcc15".
# (The -e/--env option must precede the subcommand.)
#
# <env> selects a Spack environment and thus these locations (relative to the
# project root, which is the directory holding this script):
#
#   extern/envs/<env>/view/   dependency prefix (compilers + find_package deps)
#   builds/envs/<env>/        build products (super-build tree)
#   installs/envs/<env>/      shared install prefix
#
# Subcommands:
#   concretize  run "spack -e <envdir> concretize -f" to (re)concretize the
#               Spack environment.  Extra args are passed through.
#   install     run "spack -e <envdir> install" then rebuild the environment
#               view FROM SCRATCH (remove the view root, then
#               "spack -e <envdir> env view regenerate").  Spack's regenerate
#               short-circuits on a content-hash marker and can otherwise leave a
#               stale/partial view; a clean rebuild is the only reliable cure.
#               Extra args (e.g. -j N) are passed through to "spack install".
#   config   run "cmake -S ... -B ..." (the configure step)
#   build    run "cmake --build ..."   (the build step)
#   deps     draw the package-level dependency graph of the devel/ packages by
#            delegating to the "cmake-examine deps" tool.  This is env-independent
#            (any -e/--env is ignored): invoke it as
#            "umbrella deps [cmake-examine options]".  Any arguments are passed
#            verbatim to cmake-examine, e.g. "umbrella deps -o devel-deps.png --libs".
#   test     run project-level tests.  Each test is a directory tests/<name>/
#            with an executable run.sh, invoked as "run.sh <env> <outdir>"
#            where <outdir> is builds/envs/<env>/xerosere/<name>/.  With no
#            <testname> all tests are run.  A test exits 0=pass, 77=skip,
#            other=fail; "umbrella test" exits non-zero if any failed.
#
# With no <package>, the subcommand operates on the whole super-build.
#
# With one or more <package> (sub-directory names under devel/), the subcommand
# operates on just those package(s), configured/built stand-alone into
# builds/envs/<env>/<package>/.  Their in-tree dependencies must already be
# installed into installs/envs/<env>/ (run the whole-project build first, or
# list the dependencies too) since they are located via find_package(CONFIG).
#
# [options] are any arguments beginning with "-"; they are appended verbatim to
# the underlying cmake command.  A bare token (e.g. the "32" in "-j 32") that is
# not a devel/ sub-directory is also passed through to cmake, so both
# "build -j 32" and "build -j32" work.
#
set -euo pipefail

# Sanitize the ambient compiler search-path environment.  A Spack-activated
# shell exports CPATH / CPLUS_INCLUDE_PATH / C_INCLUDE_PATH pointing at the
# environment view's include dir.  If cmake's configure step sees those, it
# records "$view/include" as an *implicit* compiler include directory and then
# STRIPS it from imported targets' SYSTEM include dirs (e.g. Arrow, HDF5) as
# redundant -- so the generated compile lines carry no "-isystem $view/include".
# At build time (a plain shell, where those vars are unset) the compiler no
# longer searches the view and the build fails with e.g. "arrow/api.h: No such
# file or directory".  Unsetting them here makes configure deterministic and
# self-contained: find_package() supplies every needed path via
# CMAKE_PREFIX_PATH, so nothing of value is lost.
unset CPATH CPLUS_INCLUDE_PATH C_INCLUDE_PATH OBJC_INCLUDE_PATH 2>/dev/null || true

self="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
root="$self"

die()   { echo "umbrella: $*" >&2; exit 1; }
run()   { echo "+ $*" >&2; "$@"; }
usage() {
    # print the leading comment block (skip the shebang, stop at first non-# line)
    awk 'NR==1{next} /^#/{sub(/^# ?/,""); if($0=="" && !seen)next; seen=1; print; next} {exit}' "$0"
    exit "${1:-0}"
}

# --- resolve the target environment and parse leading options ---------------
# Environment precedence: -e/--env option > $XEROSERE_UMBRELLA_ENV > default.
env="${XEROSERE_UMBRELLA_ENV:-gcc15}"

# Consume any options that precede the subcommand (currently -e/--env and
# -h/--help).  Everything from the subcommand onward is left in "$@".
while [ $# -ge 1 ]; do
    case "$1" in
        -h|--help) usage 0 ;;
        -e|--env)
            [ $# -ge 2 ] || die "option '$1' requires an argument"
            env="$2"; shift 2 ;;
        -e=*|--env=*) env="${1#*=}"; shift ;;
        --) shift; break ;;
        *) break ;;
    esac
done

[ $# -ge 1 ] || die "missing subcommand (config|build|test|deps); see --help"
sub="$1"; shift

# --- deps: package-level dependency graph (env-independent) -----------------
# Delegate to "cmake-examine deps".  Collect every package directory under
# devel/ (skipping the super-build CMakeLists.txt and any non-directory) and
# pass them, followed by any extra arguments, to cmake-examine.
if [ "$sub" = deps ]; then
    command -v cmake-examine >/dev/null 2>&1 || die "cmake-examine not found on PATH"
    dirs=()
    for d in "$root"/devel/*/; do
        [ -d "$d" ] || continue        # skips CMakeLists.txt and stray files
        dirs+=("${d%/}")
    done
    [ ${#dirs[@]} -gt 0 ] || die "no package directories found under devel/"
    run cmake-examine deps "${dirs[@]}" "$@"
    exit 0
fi

case "$sub" in
    config|build|test|concretize|install) ;;
    *) die "unknown subcommand '$sub' (expected config, build, test, concretize, install or deps)" ;;
esac

# --- environment-derived locations ------------------------------------------
envdir="$root/extern/envs/$env"     # directory holding spack.yaml (spack -e target)
view="$envdir/view"                 # Spack environment view root (spack.yaml: view.default.root)
build="$root/builds/envs/$env"
install="$root/installs/envs/$env"

[ -d "$envdir" ] || die "no such environment: extern/envs/$env"

# --- concretize / install: drive the Spack environment ----------------------
# These operate on the Spack environment (extern/envs/<env>) and must NOT require
# the view's toolchain to pre-exist (a fresh env has no view until installed).
if [ "$sub" = concretize ] || [ "$sub" = install ]; then
    spack="$root/extern/spack/bin/spack"
    [ -x "$spack" ] || spack="$(command -v spack 2>/dev/null)" || \
        die "spack not found at extern/spack/bin/spack or on PATH"

    case "$sub" in
        concretize)
            # Re-concretize the whole environment; -f allows spack.lock to change.
            # Extra args (e.g. --fresh) are passed through verbatim.
            run "$spack" -e "$envdir" concretize -f "$@"
            ;;
        install)
            # Install the environment, passing any extra args (e.g. -j N) through.
            run "$spack" -e "$envdir" install "$@"

            # Guarantee the view is not stale.  Spack's view regeneration
            # short-circuits when a content-hash marker file (<view>/.spack-view)
            # already matches, so a plain 'env view regenerate' -- and the
            # implicit regenerate that 'install' runs -- can be a NO-OP even when
            # the view is actually stale or partial (the failure mode seen when
            # e.g. phlex 0.3.2's CMake files went missing from the view, and the
            # likely source of the stale gcc-runtime entries).  Deleting only the
            # marker is not enough: _ensure_safe_to_replace() refuses to rebuild
            # over a non-empty, unmarked directory.  So remove the whole view
            # root and let regenerate rebuild it cleanly from the current lock --
            # the only way that reliably eliminates staleness.
            # (See spack/environment/environment.py: ViewDescriptor.regenerate,
            #  _is_up_to_date, _ensure_safe_to_replace.)
            if [ -e "$view" ] || [ -L "$view" ]; then
                run rm -rf "$view"
            fi
            run "$spack" -e "$envdir" env view regenerate
            ;;
    esac
    exit 0
fi

# --- test: run project-level tests (tests/<name>/run.sh) --------------------
# Each test's run.sh is invoked as "run.sh <env> <outdir>" and reports its
# result via exit status (0=pass, 77=skip, other=fail).  Output is directed to
# builds/envs/<env>/xerosere/<name>/.
if [ "$sub" = test ]; then
    testroot="$root/tests"
    [ -d "$testroot" ] || die "no tests/ directory"
    names=()
    if [ $# -ge 1 ]; then
        names=("$@")
    else
        for d in "$testroot"/*/; do
            [ -x "${d}run.sh" ] && names+=("$(basename "${d%/}")")
        done
    fi
    [ ${#names[@]} -gt 0 ] || die "no tests found (expected tests/<name>/run.sh)"

    rc=0; passed=(); skipped=(); failed=()
    for n in "${names[@]}"; do
        script="$testroot/$n/run.sh"
        if [ ! -x "$script" ]; then
            echo "umbrella: no such test: tests/$n/run.sh" >&2
            failed+=("$n"); rc=1; continue
        fi
        outdir="$build/xerosere/$n"
        echo "== test: $n =="
        if run "$script" "$env" "$outdir"; then
            passed+=("$n")
        else
            st=$?
            if [ "$st" -eq 77 ]; then skipped+=("$n"); else failed+=("$n"); rc=1; fi
        fi
    done

    echo "----------------------------------------------------------------"
    echo "tests: ${#passed[@]} passed, ${#skipped[@]} skipped, ${#failed[@]} failed"
    [ ${#passed[@]}  -gt 0 ] && echo "  passed:  ${passed[*]}"
    [ ${#skipped[@]} -gt 0 ] && echo "  skipped: ${skipped[*]}"
    [ ${#failed[@]}  -gt 0 ] && echo "  failed:  ${failed[*]}"
    exit "$rc"
fi

[ -x "$view/bin/g++" ] || die "environment view not built: $view/bin/g++ missing (build the Spack env first)"

# Prefer the environment view's cmake over the system one (which may be too old
# for some packages, e.g. EDepSim needs >= 3.30).  Fall back to PATH cmake only
# if the view provides none.
cmake="$view/bin/cmake"
[ -x "$cmake" ] || cmake="$(command -v cmake 2>/dev/null)" || die "no cmake in $view/bin or on PATH"

# --- split remaining args into cmake options and package names --------------
opts=()
pkgs=()
for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
        opts+=("$arg")
    elif [ -d "$root/devel/$arg" ]; then
        pkgs+=("$arg")
    else
        # not a devel/ sub-directory: treat as a cmake argument (e.g. -j 32)
        echo "umbrella: '$arg' is not a devel/ package; passing to cmake" >&2
        opts+=("$arg")
    fi
done

# Common configure flags shared by super-build and per-package builds.
config_flags=(
    -DCMAKE_C_COMPILER="$view/bin/gcc"
    -DCMAKE_CXX_COMPILER="$view/bin/g++"
    -DCMAKE_INSTALL_PREFIX="$install"
    -DCMAKE_BUILD_TYPE=Release
    -DCMAKE_CXX_STANDARD=23
)

# --- detect the "view-shadowed sub-build cache" trap ------------------------
# When a package is promoted from the Spack view into devel/ (e.g. wire-cell-
# toolkit), a consumer sub-build that was first configured BEFORE the devel
# package was installed will have cached the dependency's headers/libs into the
# view.  find_library/find_path never re-evaluate a cached hit, and the
# super-build's ExternalProject re-runs only the build step (BUILD_ALWAYS), never
# reconfigure -- so the sub-build keeps linking the stale, wrong-version view
# copy (symptom: undefined-reference link errors against a since-changed ABI).
#
# Scan every CMakeCache.txt under a build root for a resolved *_LIBRARY /
# non-INCLUDE *_DIR entry whose value lives under the view WHILE the shared
# install prefix now provides that same artifact (swap the view prefix for the
# install prefix and test existence).  Genuine view-only externals (Boost,
# Arrow, ...) have no install counterpart and are not reported.  Emits a warning
# and the exact remedy; never fatal.
warn_stale_caches() {
    local scanroot="$1"
    [ -d "$scanroot" ] || return 0
    local hits=0 cache line name val rel cand relb
    declare -A _stale_pkgs=()
    while IFS= read -r cache; do
        while IFS= read -r line; do
            name="${line%%:*}"
            case "$name" in *_INCLUDE_DIR) continue ;; esac
            val="${line#*=}"
            case "$val" in "$view"/*) ;; *) continue ;; esac
            rel="${val#"$view"/}"
            cand="$install/$rel"
            [ -e "$cand" ] || continue
            if [ "$hits" -eq 0 ]; then
                echo "umbrella: WARNING: stale sub-build cache(s) pinned to the Spack view;" >&2
                echo "umbrella:   the install prefix now provides the same artifact, so these" >&2
                echo "umbrella:   builds would keep linking the OLD view copy until removed:" >&2
            fi
            hits=$((hits+1))
            echo "umbrella:   [$cache]" >&2
            echo "umbrella:     $name = $val" >&2
            echo "umbrella:     shadows $cand" >&2
            relb="${cache#"$build"/}"
            _stale_pkgs["$build/${relb%%/*}"]=1
        done < <(grep -E '^[A-Za-z0-9_]+_(LIBRARY|DIR):(FILEPATH|PATH)=' "$cache" 2>/dev/null || true)
    done < <(find "$scanroot" -name CMakeCache.txt 2>/dev/null)
    if [ "$hits" -gt 0 ]; then
        echo "umbrella:   remedy: remove the affected build dir(s) and reconfigure:" >&2
        local p
        for p in "${!_stale_pkgs[@]}"; do
            echo "umbrella:     rm -rf $p" >&2
        done
        echo "umbrella:   then re-run: umbrella -e $env config" >&2
    fi
}

# --- whole super-build (no packages listed) ---------------------------------
if [ ${#pkgs[@]} -eq 0 ]; then
    case "$sub" in
        config)
            run "$cmake" -S "$root/devel" -B "$build" \
                "${config_flags[@]}" \
                -DCMAKE_PREFIX_PATH="$view" \
                "${opts[@]}"
            # Warn about any stale sub-build caches left by earlier builds so the
            # next 'build' does not silently link a shadowed view copy.
            warn_stale_caches "$build"
            ;;
        build)
            run "$cmake" --build "$build" "${opts[@]}"
            ;;
    esac
    exit 0
fi

# --- one or more specific packages ------------------------------------------
# Stand-alone configure/build per package into builds/envs/<env>/<package>/.
# Siblings are found via CMAKE_PREFIX_PATH: the shared install prefix (already
# installed siblings) followed by the Spack view (external deps).  RPATH flags
# mirror the super-build so stand-alone installs also run in place.
for pkg in "${pkgs[@]}"; do
    src="$root/devel/$pkg"
    pbuild="$build/$pkg"
    case "$sub" in
        config)
            run "$cmake" -S "$src" -B "$pbuild" \
                "${config_flags[@]}" \
                -DCMAKE_PREFIX_PATH="$install;$view" \
                -DCMAKE_POLICY_DEFAULT_CMP0167=NEW \
                -DCMAKE_INSTALL_RPATH_USE_LINK_PATH=TRUE \
                -DCMAKE_INSTALL_RPATH="$install/lib;$install/lib64" \
                "${opts[@]}"
            warn_stale_caches "$pbuild"
            ;;
        build)
            [ -d "$pbuild" ] || die "package '$pkg' not configured: run 'umbrella -e $env config $pkg' first"
            run "$cmake" --build "$pbuild" "${opts[@]}"
            ;;
    esac
done
